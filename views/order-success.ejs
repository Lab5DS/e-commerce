<!-- views/order-success.ejs -->
<div class="text-center py-5">
  <div class="success-icon">✓</div>
  <h1 class="fw-800 mb-1">¡Gracias por tu compra!</h1>
  <p class="text-muted mb-4">Tu pedido fue confirmado y está siendo procesado.</p>
  
  <div class="success-card card">
    <div class="card-header">
      <i class="bi bi-bag-check me-2"></i> Detalles del Pedido
    </div>
    <div class="card-body text-start p-4">
      <div class="row g-2">
        <div class="col-6 text-muted">Orden #</div>
        <div class="col-6 fw-bold"><%= order.id %></div>
        
        <div class="col-6 text-muted">Total</div>
        <div class="col-6 fw-bold" style="color:var(--accent)">
           $<%= (Number(order.total) || 0).toFixed(2) %>
        </div>
        <pre class="text-start bg-light p-3 mt-3" style="font-size:0.75rem;"><%= JSON.stringify(order, null, 2) %></pre>

        <div class="col-6 text-muted">Estado</div>
        <div class="col-6">
          <span class="badge-stock"><i class="bi bi-check2"></i> Pagado</span>
        </div>
      </div>
    </div>
  </div>
  
  <a href="/" class="btn btn-primary mt-4">
    <i class="bi bi-shop me-2"></i>Seguir comprando
  </a>
</div>
